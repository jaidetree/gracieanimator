# Nix toolchain (python, postgresql, tailwindcss CLI, uv)
use flake

# Python deps -> project-local .venv on PATH
layout python python3.12

# Install/refresh deps from requirements.txt on each reload (cheap once cached)
if [ -f requirements.txt ]; then
  uv pip install --quiet --requirement requirements.txt
fi

# Run the app in development mode (settings.py defaults APP_ENV to production).
export APP_ENV="development"

# Project-local Postgres (data + unix socket under .pg/) so `runserver` and
# tests work without a system-wide cluster. See scripts/db.
export PGDATA="$PWD/.pg/data"
export PGHOST="$PWD/.pg"
export PGPORT="5432"
export PGDATABASE="gracie"

# Personal overrides — secrets, port changes, APP_ENV=production to test
# hardening locally (gitignored; see .envrc.local.example).
source_env_if_exists .envrc.local
