# Copy to .env for local development (gitignored). The dev shell (.envrc) sets
# APP_ENV=development; settings.py otherwise defaults APP_ENV to "production".
# DEBUG follows APP_ENV (on unless production) — set it here only to override.

# Used for cryptographic signing. Generate one for production.
SECRET_KEY=dev-insecure-change-me

# Comma-separated. Enforced only when DEBUG is off (i.e. APP_ENV=production).
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection. With no host, psycopg uses PGHOST (the absolute socket
# dir exported by .envrc) — the project-local cluster (see scripts/db).
DATABASE_URL=postgres:///gracie
