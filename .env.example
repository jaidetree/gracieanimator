# Copy to .env for local development (gitignored).

# Toggles dev vs prod behaviour. NEVER true in production.
DEBUG=true

# Used for cryptographic signing. Generate one for production.
SECRET_KEY=dev-insecure-change-me

# Comma-separated. Ignored when DEBUG=true.
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection. Defaults to the project-local cluster (see .envrc / scripts/db-init.sh).
DATABASE_URL=postgres:///gracie?host=.pg
